SERVER_PORT=8080

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/arkmem
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_DATASOURCE_MAXIMUM_POOL_SIZE=10

ARKMEM_STORAGE_PROVIDER=postgres
ARKMEM_API_INTERNAL_TOKEN=
ARKMEM_PROMPT_LANGUAGE=en

ARKMEM_LLM_PROVIDER=local
ARKMEM_LLM_API_KEY=
ARKMEM_LLM_BASE_URL=https://api.openai.com/v1
ARKMEM_LLM_MODEL=gpt-4.1-nano-2025-04-14
ARKMEM_EMBEDDING_PROVIDER=local
ARKMEM_EMBEDDING_API_KEY=
ARKMEM_EMBEDDING_BASE_URL=https://api.openai.com/v1
ARKMEM_EMBEDDING_MODEL=text-embedding-3-small
ARKMEM_EMBEDDING_LOCAL_DIMENSIONS=384

ARKMEM_DEFAULT_TOP_K=10
ARKMEM_DEFAULT_THRESHOLD=0.0
ARKMEM_DUPLICATE_THRESHOLD=0.985
ARKMEM_FALLBACK_EXTRACTION_ENABLED=true

# Production OpenAI-compatible provider example:
# OPENAI_API_KEY=your-api-key
# ARKMEM_LLM_PROVIDER=openai
# ARKMEM_EMBEDDING_PROVIDER=openai
# ARKMEM_LLM_MODEL=gpt-4.1-nano-2025-04-14
# ARKMEM_EMBEDDING_MODEL=text-embedding-3-small
